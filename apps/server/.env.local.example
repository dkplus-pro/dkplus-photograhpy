# Copy to .env.local for local development. Do not commit .env.local.
NODE_ENV=development
HOST=127.0.0.1
PORT=4010

# Required for all /api/* admin routes. Send as: Authorization: Bearer <token>
ADMIN_TOKEN=replace-with-a-long-random-token

# Optional comma-separated browser origins for the admin app.
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# Default assumes the server runs from apps/server and the repo root has data/photos.json.
DATA_FILE=../../data/photos.json
UPLOAD_DIR=./uploads
PUBLIC_BASE_URL=http://localhost:4010/uploads

# Tencent COS. Leave COS_ENABLED=false to store uploads locally.
COS_ENABLED=false
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
COS_PREFIX=photos
COS_CDN_BASE_URL=
