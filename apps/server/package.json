{
  "name": "@dkplus/server",
  "version": "0.1.0",
  "private": true,
  "description": "Admin Koa API for DKPlus Photography JSON data, uploads, COS storage, and EXIF metadata.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "npm run build && node --test \"dist/**/*.test.js\""
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/multer": "^4.0.0",
    "@koa/router": "^13.1.0",
    "dotenv": "^16.4.7",
    "exifr": "^7.1.3",
    "koa": "^2.15.3",
    "koa-bodyparser": "^4.4.1",
    "mime-types": "^2.1.35"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/koa": "^2.15.0",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa__cors": "^5.0.1",
    "@types/koa__multer": "^2.0.8",
    "@types/koa__router": "^12.0.5",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.17.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  },
  "optionalDependencies": {
    "cos-nodejs-sdk-v5": "^2.14.8"
  },
  "type": "module"
}
