{
  "name": "dkplus-photography",
  "version": "0.1.0",
  "private": true,
  "description": "Static photography gallery and admin tooling for dk+ photography.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "node --test tests/repo-hygiene.test.mjs && turbo run test",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,jsonc,md,yml,yaml,css,scss,html}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,jsonc,md,yml,yaml,css,scss,html}\"",
    "clean": "turbo run clean && rm -rf node_modules .turbo dist coverage"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "prettier": "3.9.4",
    "turbo": "2.10.4",
    "typescript": "6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
